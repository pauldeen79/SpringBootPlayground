## Ignore VS Code and Java temporary files, build results, and
## files generated by popular VC Code add-ons.

# User-specific files
*.env

# --- Build Outputs ---
target/
*.class
*.war
*.ear
*.jar

# VS Code files for those working on multiple tools
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Local History for Visual Studio Code
.history/

# Built Visual Studio Code Extensions
*.vsix

# --- VS Code & Java Extensions ---
.project
.classpath
.factorypath
.settings/
bin/

# --- Build Outputs ---
target/
build/
*.class
*.war
*.ear
*.jar

# --- Other IDE's (just for sure) ---
.idea/
*.iml

# --- OS ---
.DS_Store
Thumbs.db